# Sentinel EMS connection
SENTINEL_EMS_URL=https://your-instance.trial.sentinelcloud.com
SENTINEL_EMS_USERNAME=admin
SENTINEL_EMS_PASSWORD=your-password-here
SENTINEL_EMS_NAMESPACE_ID=

# API key to protect your MCP endpoint (recommended)
# Anyone connecting to your server must pass this in the x-api-key header
MCP_API_KEY=change-me-to-a-strong-random-secret

# HTTP port (Railway sets this automatically)
PORT=3000
